# Copy this into Streamlit Cloud → your app → Settings → Secrets (or to a local
# .streamlit/secrets.toml, which is gitignored) to make keeper submissions
# durable. Picks are stored in THIS app's own GitHub repo on a separate data
# branch — no external service to manage. Without a token the app falls back to
# local files (which reset on Streamlit Cloud restarts).

# A GitHub fine-grained token with "Contents: Read and write" on the repo.
github_token = "github_pat_xxxxxxxxxxxxxxxxxxxxxxxx"

# Optional — defaults shown. Only change if you forked/renamed the repo.
# github_repo = "fabfreebird23/babies-and-boomer"
# github_branch = "keeper-data"
